{
  "uid": "vn-drift-detection",
  "title": "VN News Headline Drift — Distribution Shift Monitor",
  "tags": ["drift", "vietnamese", "nlp", "bonus-p3"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "🔴 Drift Status — Overall (10s summary)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 6},
      "targets": [{
        "expr": "max(vn_drift_significant)",
        "legendFormat": "drift"
      }],
      "fieldConfig": {"defaults": {"mappings": [
        {"type": "value", "value": "1", "text": "🔴 SIGNIFICANT DRIFT — Investigate"},
        {"type": "value", "value": "0.5", "text": "🟡 MODERATE DRIFT — Monitor"},
        {"type": "value", "value": "0", "text": "🟢 STABLE — No action needed"}
      ], "thresholds": {"mode": "absolute", "steps": [
        {"value": 0, "color": "green"},
        {"value": 0.5, "color": "yellow"},
        {"value": 1, "color": "red"}
      ]}}}
    },
    {
      "id": 2,
      "title": "PSI by Feature",
      "type": "bargauge",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 6},
      "targets": [{"expr": "vn_drift_psi", "legendFormat": "{{feature}}"}],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 0.5, "thresholds": {"mode": "absolute", "steps": [
        {"value": 0, "color": "green"},
        {"value": 0.1, "color": "yellow"},
        {"value": 0.25, "color": "red"}
      ]}}}
    },
    {
      "id": 3,
      "title": "KS Statistic by Feature",
      "type": "bargauge",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 6},
      "targets": [{"expr": "vn_drift_ks_stat", "legendFormat": "{{feature}}"}],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [
        {"value": 0, "color": "green"},
        {"value": 0.1, "color": "yellow"},
        {"value": 0.2, "color": "red"}
      ]}}}
    },
    {
      "id": 4,
      "title": "PSI Over Time — text_length",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 7},
      "targets": [
        {"expr": "vn_drift_psi{feature=\"text_length\"}", "legendFormat": "text_length PSI"},
        {"expr": "0.1", "legendFormat": "moderate threshold"},
        {"expr": "0.25", "legendFormat": "significant threshold"}
      ],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [
        {"value": 0, "color": "green"}, {"value": 0.1, "color": "yellow"}, {"value": 0.25, "color": "red"}
      ]}}}
    },
    {
      "id": 5,
      "title": "PSI Over Time — tone_mark_ratio",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 7},
      "targets": [
        {"expr": "vn_drift_psi{feature=\"tone_mark_ratio\"}", "legendFormat": "tone_mark PSI"},
        {"expr": "0.1", "legendFormat": "moderate threshold"},
        {"expr": "0.25", "legendFormat": "significant threshold"}
      ],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [
        {"value": 0, "color": "green"}, {"value": 0.1, "color": "yellow"}, {"value": 0.25, "color": "red"}
      ]}}}
    },
    {
      "id": 6,
      "title": "PSI Over Time — english_word_ratio (the canary)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 13, "w": 12, "h": 7},
      "targets": [
        {"expr": "vn_drift_psi{feature=\"english_word_ratio\"}", "legendFormat": "english_ratio PSI"},
        {"expr": "0.1", "legendFormat": "moderate threshold"},
        {"expr": "0.25", "legendFormat": "significant threshold"}
      ],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [
        {"value": 0, "color": "green"}, {"value": 0.1, "color": "yellow"}, {"value": 0.25, "color": "red"}
      ]}}},
      "description": "English word ratio is the most sensitive drift signal — loanwords and tech terms enter VN news rapidly. This is our canary metric."
    },
    {
      "id": 7,
      "title": "KL Divergence by Feature",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 13, "w": 12, "h": 7},
      "targets": [
        {"expr": "vn_drift_kl{feature=\"text_length\"}", "legendFormat": "text_length KL"},
        {"expr": "vn_drift_kl{feature=\"tone_mark_ratio\"}", "legendFormat": "tone_mark KL"},
        {"expr": "vn_drift_kl{feature=\"english_word_ratio\"}", "legendFormat": "english_ratio KL"}
      ],
      "fieldConfig": {"defaults": {}}
    },
    {
      "id": 8,
      "title": "Top-5 Features by Drift Severity (last value)",
      "type": "table",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 6},
      "targets": [{
        "expr": "sort_desc(vn_drift_psi)",
        "format": "table",
        "instant": true
      }],
      "fieldConfig": {"defaults": {}}
    }
  ],
  "time": {"from": "now-7d", "to": "now"}
}
